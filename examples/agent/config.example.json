{
  "bot_id": "your-bot-id",
  "bot_secret": "your-bot-secret",
  "anthropic_api_key": "your-anthropic-api-key",
  "anthropic_base_url": "",
  "model": "claude-sonnet-4-6",
  "system_prompt": "你是一个AI助手，可以使用工具来读写文件和执行命令。请用中文回答问题。",
  "max_tokens": 4096,
  "working_dir": "/path/to/workspace",
  "bash_patterns": [
    "^ls\\b",
    "^cat\\b",
    "^head\\b",
    "^tail\\b",
    "^grep\\b",
    "^find\\b",
    "^wc\\b",
    "^echo\\b",
    "^pwd$",
    "^tree\\b",
    "^git\\s"
  ],
  "max_turns": 20
}
